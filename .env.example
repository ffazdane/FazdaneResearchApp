# Tastytrade OAuth2, preferred
TT_CLIENT_ID=
TT_SECRET=
TT_REFRESH=

# Optional fallback when OAuth is not available and 2FA is disabled
TASTYTRADE_USERNAME=
TASTYTRADE_PASSWORD=

# production or sandbox
TASTYTRADE_ENVIRONMENT=production

# Optional: set this to a persistent production volume outside the git checkout.
# Leave blank locally to use data/options_liquidity/options_liquidity.sqlite.
OPTIONS_LIQUIDITY_DB_PATH=

# Optional: set this to a persistent production volume outside the git checkout.
# Leave blank locally to use data/portfolio_performance/portfolio_performance.sqlite.
PORTFOLIO_PERFORMANCE_DB_PATH=

# Optional: set this to a persistent production volume outside the git checkout.
# Leave blank locally to use data/earnings_calendar/earnings_calendar.sqlite.
EARNINGS_CALENDAR_DB_PATH=
